                      },
                      "spec": {
                        "query": "from(bucket: \"rpi_metricas\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"diskio\")\r\n  |> filter(fn: (r) => r[\"name\"] == \"mmcblk0\") // Tu SD principal\r\n  |> filter(fn: (r) => r[\"_field\"] == \"write_bytes\" or r[\"_field\"] == \"read_bytes\")\r\n  |> derivative(unit: 1s, nonNegative: true)\r\n  // Convertimos de Bytes/s a Megabytes/s\r\n  |> map(fn: (r) => ({ r with _value: r._value / 1024.0 / 1024.0 }))\r\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\r\n  |> map(fn: (r) => ({\r\n      r with\r\n      _field: if r._field == \"write_bytes\" then \"Escritura\"\r\n              else if r._field == \"read_bytes\" then \"Lectura\"\r\n              else r._field\r\n    }))\r\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> keep(columns: [\"_time\", \"Escritura\", \"Lectura\"])"
