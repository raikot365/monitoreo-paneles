      "panel-9": {
        "kind": "Panel",
        "spec": {
          "id": 9,
          "title": "Tráfico de Red",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "afjopmxy9xvr4e"
                      },
                      "spec": {
                        "query": "from(bucket: \"rpi_metricas\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"net\")\r\n  |> filter(fn: (r) => r[\"interface\"] == \"wlan0\") // Tu antena WiFi\r\n  |> filter(fn: (r) => r[\"_field\"] == \"bytes_sent\" or r[\"_field\"] == \"bytes_recv\")\r\n  |> derivative(unit: 1s, nonNegative: true)\r\n  // Convertimos a Kilobytes/s\r\n  |> map(fn: (r) => ({ r with _value: r._value / 1024.0 }))\r\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\r\n  |> map(fn: (r) => ({\r\n      r with\r\n      _field: if r._field == \"bytes_sent\" then \"Subida\"\r\n              else if r._field == \"bytes_recv\" then \"Bajada\"\r\n              else r._field\r\n    }))\r\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> keep(columns: [\"_time\", \"Subida\", \"Bajada\"])"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
